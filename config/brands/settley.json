{
  "id": "settley",
  "name": "Settley",
  "description": "Settley is a tokenised real estate platform that lets anyone invest in fractional property ownership through blockchain. Users can buy, sell, and earn yield from real-world property assets tokenised on-chain. Designed for people who want exposure to real estate without the capital barrier of buying a whole property. Authority and trust are the core brand values.",
  "tone": "authoritative, clear, trustworthy, premium",
  "audience": "retail investors, property-curious millennials, DeFi users seeking real-world assets, high-income renters priced out of property ownership",
  "cta": "Invest in Property",
  "logoPath": null,
  "visual": {
    "primaryColor": "#1b4f72",
    "secondaryColor": "#d5e8f7",
    "accentColor": "#2e86c1",
    "surfaceColor": "#f4f9fd"
  },
  "defaults": {
    "platformTargets": ["tiktok", "instagram"],
    "goal": "awareness",
    "hashtags": ["#settley", "#tokenisedrealestate", "#rwa", "#realestateinvesting", "#fractionalownership", "#web3realestate"]
  },
  "providers": {
    "plannerModel": "glm-4.5",
    "imageModel": "fal-ai/flux/schnell"
  },
  "contentRecipes": [
    {
      "id": "property-showcase",
      "name": "Property Showcase",
      "routeFamily": "carousel",
      "workflowType": "slideshow",
      "platformTargets": ["instagram", "tiktok"],
      "defaultPriority": 80,
      "preferredAssetTypes": ["product_photo"],
      "contentTypeId": "property-showcase"
    },
    {
      "id": "market-insight",
      "name": "Market Insight",
      "routeFamily": "infographic",
      "workflowType": "slideshow",
      "platformTargets": ["instagram", "linkedin"],
      "defaultPriority": 100,
      "preferredAssetTypes": ["screenshot", "document", "product_photo"],
      "contentTypeId": "market-insight"
    },
    {
      "id": "settley-flyer",
      "name": "Settley Flyer",
      "routeFamily": "flyer",
      "workflowType": "reference-edit",
      "platformTargets": ["instagram", "linkedin"],
      "defaultPriority": 115,
      "preferredAssetTypes": ["logo", "product_photo", "document"],
      "visualStyleHint": "premium trust-building flyer with CTA and logo lockup"
    }
  ],
  "defaultContentType": "property-showcase",
  "contentTypes": [
    {
      "id": "property-showcase",
      "name": "Property Showcase",
      "imageStyle": "premium architectural photography, clean lines, trust-building real estate visual, bright natural lighting",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "hero", "type": "generated_image", "textFields": ["propertyName", "location"], "imagePromptTemplate": "Architectural hero shot of {propertyName}", "layout": "image_focus" },
        { "role": "detail", "type": "generated_image", "textFields": ["featureName", "description"], "imagePromptTemplate": "Interior detail shot showing {featureName}", "layout": "image_focus" },
        { "role": "detail", "type": "generated_image", "textFields": ["featureName", "description"], "imagePromptTemplate": "Interior detail shot showing {featureName}", "layout": "image_focus" },
        { "role": "detail", "type": "generated_image", "textFields": ["featureName", "description"], "imagePromptTemplate": "Interior detail shot showing {featureName}", "layout": "image_focus" },
        { "role": "cta", "type": "text_only", "textFields": ["headline", "cta"], "imagePromptTemplate": null, "layout": "cta_banner" }
      ]
    },
    {
      "id": "market-insight",
      "name": "Market Insight",
      "imageStyle": "premium architectural photography, clean lines, trust-building real estate visual, bright natural lighting",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "data", "type": "generated_image", "textFields": ["headline", "statistic"], "imagePromptTemplate": "Data visualisation for real estate market insight", "layout": "image_focus" },
        { "role": "analysis", "type": "generated_image", "textFields": ["insight", "explanation"], "imagePromptTemplate": "Market analysis visual with charts and graphs", "layout": "image_focus" },
        { "role": "cta", "type": "text_only", "textFields": ["headline", "cta"], "imagePromptTemplate": null, "layout": "cta_banner" }
      ]
    },
    {
      "id": "investment-update",
      "name": "Investment Update",
      "imageStyle": "premium architectural photography, clean lines, trust-building real estate visual, bright natural lighting",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "update", "type": "generated_image", "textFields": ["headline", "body", "metrics"], "imagePromptTemplate": "Investment performance visual with premium aesthetic", "layout": "image_focus" }
      ]
    }
  ]
}
