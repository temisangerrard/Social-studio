{
  "id": "autobett",
  "name": "AutoBett",
  "description": "Autobett is an onchain autonomous betting platform where AI agents place bets on your behalf using smart contracts. Users deposit crypto, set risk parameters, and the AI manages positions across sports, prediction markets, and onchain games. Built for crypto-native audiences who want passive exposure to prediction markets without manual trading.",
  "tone": "bold, hype, crypto-native, confident",
  "audience": "crypto degens, DeFi users, sports bettors exploring onchain, web3 early adopters",
  "cta": "Connect Wallet",
  "logoPath": null,
  "visual": {
    "primaryColor": "#f0a500",
    "secondaryColor": "#1a1a2e",
    "accentColor": "#e94560",
    "surfaceColor": "#16213e"
  },
  "defaults": {
    "platformTargets": ["tiktok", "instagram"],
    "goal": "awareness",
    "hashtags": ["#autobett", "#onchainbetting", "#defi", "#cryptobetting", "#web3", "#aiagents"]
  },
  "providers": {
    "plannerModel": "glm-4.5",
    "imageModel": "fal-ai/flux/schnell"
  },
  "defaultContentType": "launch-post",
  "contentTypes": [
    {
      "id": "launch-post",
      "name": "Launch Post",
      "imageStyle": "bold neon-lit crypto/sports visual, dark background, high contrast, futuristic UI aesthetic",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "hero", "type": "generated_image", "textFields": ["headline", "subtitle"], "imagePromptTemplate": "Neon-lit announcement visual for {headline}", "layout": "image_focus" }
      ]
    },
    {
      "id": "feature-highlight",
      "name": "Feature Highlight",
      "imageStyle": "bold neon-lit crypto/sports visual, dark background, high contrast, futuristic UI aesthetic",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "feature", "type": "generated_image", "textFields": ["featureName", "description"], "imagePromptTemplate": "Futuristic UI showcase of {featureName}", "layout": "image_focus" },
        { "role": "benefit", "type": "generated_image", "textFields": ["benefitText"], "imagePromptTemplate": "Neon visual showing benefit of {featureName}", "layout": "image_focus" },
        { "role": "cta", "type": "text_only", "textFields": ["headline", "cta"], "imagePromptTemplate": null, "layout": "cta_banner" }
      ]
    },
    {
      "id": "community-update",
      "name": "Community Update",
      "imageStyle": "bold neon-lit crypto/sports visual, dark background, high contrast, futuristic UI aesthetic",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "update", "type": "generated_image", "textFields": ["headline", "body"], "imagePromptTemplate": "Community update visual with neon accents", "layout": "image_focus" }
      ]
    },
    {
      "id": "odds-showcase",
      "name": "Odds Showcase",
      "imageStyle": "bold neon-lit crypto/sports visual, dark background, high contrast, futuristic UI aesthetic",
      "platformTargets": ["tiktok", "instagram"],
      "slideBlueprint": [
        { "role": "event", "type": "generated_image", "textFields": ["eventName", "date"], "imagePromptTemplate": "Neon sports event visual for {eventName}", "layout": "image_focus" },
        { "role": "odds", "type": "generated_image", "textFields": ["matchup", "odds"], "imagePromptTemplate": "Odds breakdown visual for {matchup}", "layout": "image_focus" },
        { "role": "odds", "type": "generated_image", "textFields": ["matchup", "odds"], "imagePromptTemplate": "Odds breakdown visual for {matchup}", "layout": "image_focus" },
        { "role": "odds", "type": "generated_image", "textFields": ["matchup", "odds"], "imagePromptTemplate": "Odds breakdown visual for {matchup}", "layout": "image_focus" },
        { "role": "cta", "type": "text_only", "textFields": ["headline", "cta"], "imagePromptTemplate": null, "layout": "cta_banner" }
      ]
    }
  ]
}
