# Server
PORT=3000
NODE_ENV=development

# Image generation (FAL.ai)
FAL_KEY=your_fal_key_here
FAL_MODEL=fal-ai/flux/schnell
IMAGE_GENERATION_MAX_CONCURRENT=1
IMAGE_GENERATION_MIN_DELAY_MS=750
VIDEO_GENERATION_MAX_CONCURRENT=1
VIDEO_GENERATION_MIN_DELAY_MS=1500

# Optional video provider (off by default unless a key is present)
TOKENROUTER_API_KEY=your_tokenrouter_key_here
TOKENROUTER_API_URL=https://api.tokenrouter.example/v1
TOKENROUTER_VIDEO_MODEL=HappyHorse-1.0-t2

# LLM — Zhipu GLM (used by planner and assistant)
GLM_API_KEY=your_glm_api_key_here
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash

# Playwright (for rendering)
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Voice generation (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
